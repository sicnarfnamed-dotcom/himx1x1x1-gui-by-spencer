task.spawn(function()
    while true do
        for i = 0, 1, 0.02 do
            if not screenGui:FindFirstChild("MasterFrame") then break end
            local mf = screenGui.MasterFrame
            local wave = math.sin(i * math.pi)
            local color = Color3.fromRGB(0, 130 + (wave * 125), 50 + (wave * 50))
            if mf:FindFirstChild("LeftOuter") and mf:FindFirstChild("RightOuter") then
                mf.LeftOuter.BackgroundColor3 = color
                mf.RightOuter.BackgroundColor3 = color
            end
            task.wait(0.04)
        end
    end
end)
