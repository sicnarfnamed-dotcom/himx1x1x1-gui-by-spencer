local function processSliderMovement(input)
    local relativeX = math.clamp((input.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
    sliderHandle.Position = UDim2.new(relativeX, -7, 0.5, -9)
    local raw = _G.HimxConfig.minDistance + (relativeX * (_G.HimxConfig.maxDistance - _G.HimxConfig.minDistance))
    _G.HimxConfig.currentDistance = math.floor(raw * 10) / 10
    if _G.HimxUpdateLabel then _G.HimxUpdateLabel(_G.HimxConfig.currentDistance) end
end

sliderHandle.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then _G.HimxConfig.isSliding = true end end)
game:GetService("UserInputService").InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then _G.HimxConfig.isSliding = false end end)
game:GetService("UserInputService").InputChanged:Connect(function(input) if _G.HimxConfig.isSliding and input.UserInputType == Enum.UserInputType.MouseMovement then processSliderMovement(input) end end)

