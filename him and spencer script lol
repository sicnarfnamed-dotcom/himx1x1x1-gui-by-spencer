local function getTarget()
    if _G.HimxConfig.targetText == "" then return nil end
    local search = string.lower(_G.HimxConfig.targetText)
    for _, p in pairs(players:GetPlayers()) do
        if p ~= localPlayer and p.Name ~= localPlayer.Name then
            if string.find(string.lower(p.Name), search) or string.find(string.lower(p.DisplayName), search) then return p end
        end
    end
    return nil
end

runService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    if not cam then return end
    local target = getTarget()
    if _G.HimxConfig.viewPlayer and target and target.Character and target.Character:FindFirstChild("Humanoid") then
        cam.CameraType = Enum.CameraType.Custom
        cam.CameraSubject = target.Character.Humanoid
    else
        if localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") and cam.CameraSubject ~= localPlayer.Character.Humanoid and not _G.HimxConfig.viewPlayer then
            cam.CameraSubject = localPlayer.Character.Humanoid
        end
    end
end)

runService.Heartbeat:Connect(function()
    local char = localPlayer.Character
    if not char then return end
    local hum, root, cam = char:FindFirstChild("Humanoid"), char:FindFirstChild("HumanoidRootPart"), workspace.CurrentCamera
    
    local target = getTarget()
    if target and target.Character and target.Character:FindFirstChild("Humanoid") and target.Character:FindFirstChild("HumanoidRootPart") then
        hpLabel.Text = "TARGET HP: " .. math.floor(target.Character.Humanoid.Health) .. " / " .. math.floor(target.Character.Humanoid.MaxHealth)
        speedLabel.Text = "TARGET SPEED: " .. math.floor(target.Character.HumanoidRootPart.AssemblyLinearVelocity.Magnitude) .. " STUDS/S"
    else
        hpLabel.Text = "TARGET HP: NO TARGET"
        speedLabel.Text = "TARGET SPEED: 0 STUDS/S"
    end
    
    if _G.HimxConfig.FlingMode and root and hum and hum.Health > 0 then
        local originalVelocity = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(99999, 99999, 99999)
        runService.PostSimulation:Wait()
        if root then root.AssemblyLinearVelocity = originalVelocity end
    end
    
    if _G.SpencerResetConfig.antiVoidActive and hum and root and hum.Health > 0 then
        if root.Position.Y < -350 then
            if not _G.HimxIsPhantomActive then _G.HimxIsPhantomActive = true _G.HimxPhantomY = root.Position.Y cam.CameraType = Enum.CameraType.Scriptable end
            root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = Vector3.zero, Vector3.zero
            root.CFrame = CFrame.new(root.Position.X, -350, root.Position.Z)
            _G.HimxPhantomY = _G.HimxPhantomY - 4
            cam.CFrame = CFrame.new(root.Position.X, _G.HimxPhantomY + 10, root.Position.Z + 20) * CFrame.Angles(math.rad(-25), 0, 0)
        else
            if _G.HimxIsPhantomActive then _G.HimxIsPhantomActive = false cam.CameraType = Enum.CameraType.Custom if hum then cam.CameraSubject = hum end end
        end
    else
        if _G.HimxIsPhantomActive then _G.HimxIsPhantomActive = false cam.CameraType = Enum.CameraType.Custom if hum then cam.CameraSubject = hum end end
    end
    
    if _G.SpencerResetConfig.autoResetActive and hum and hum.Health > 0 then
        if hum.Health < _G.SpencerResetConfig.lastHealth then hum.Health = 0 _G.SpencerResetConfig.lastHealth = 100 else _G.SpencerResetConfig.lastHealth = hum.Health end
    else _G.SpencerResetConfig.lastHealth = 100 end
    
    if not _G.HimxConfig.isLooping then return end
    if target and target.Character and root then
        local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local offset = Vector3.zero
            if _G.HimxConfig.posState == "Front" then offset = tRoot.CFrame.LookVector * _G.HimxConfig.currentDistance
            elseif _G.HimxConfig.posState == "Back" then offset = tRoot.CFrame.LookVector * -_G.HimxConfig.currentDistance
            elseif _G.HimxConfig.posState == "Above" then offset = tRoot.CFrame.UpVector * _G.HimxConfig.currentDistance end
            root.CFrame = CFrame.new(tRoot.Position + offset, tRoot.Position)
            if not _G.HimxConfig.FlingMode then
                root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = Vector3.zero, Vector3.zero
            end
        end
    end
end)

task.spawn(function()
    while true do
        for i = 0, 1, 0.02 do
            if not screenGui:FindFirstChild("MasterFrame") then break end
            local mf = screenGui.MasterFrame
            local wave = math.sin(i * math.pi)
            local color = Color3.fromRGB(0, 130 + (wave * 125), 50 + (wave * 50))
            if mf:FindFirstChild("LeftOuter") and mf:FindFirstChild("RightOuter") then
                mf.LeftOuter.BackgroundColor3 = color
                mf.RightOuter.BackgroundColor3 = color
            end
            task.wait(0.04)
        end
    end
end)
