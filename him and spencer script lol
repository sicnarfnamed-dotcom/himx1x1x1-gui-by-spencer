runService.Heartbeat:Connect(function()
    local char = localPlayer.Character
    if not char then return end
    local hum, root, cam = char:FindFirstChild("Humanoid"), char:FindFirstChild("HumanoidRootPart"), workspace.CurrentCamera
    if not hum or not root or not cam then return end
    
    if _G.HimxConfig.InfPosActive and _G.HimxConfig.InfPosCF then
        root.CFrame = _G.HimxConfig.InfPosCF
        root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = Vector3.zero, Vector3.zero
    end
    
    local target = getTarget()
    if target and target.Character and target.Character:FindFirstChild("Humanoid") and target.Character:FindFirstChild("HumanoidRootPart") then
        hpLabel.Text = "TARGET HP: " .. math.floor(target.Character.Humanoid.Health) .. " / " .. math.floor(target.Character.Humanoid.MaxHealth)
        speedLabel.Text = "TARGET SPEED: " .. math.floor(target.Character.HumanoidRootPart.AssemblyLinearVelocity.Magnitude) .. " STUDS/S"
    else
        hpLabel.Text = "TARGET HP: NO TARGET"
        speedLabel.Text = "TARGET SPEED: 0 STUDS/S"
    end
    
    if _G.HimxConfig.FlingMode and hum.Health > 0 and not _G.HimxConfig.InfPosActive then
        local originalVelocity = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(99999, 99999, 99999)
        runService.PostSimulation:Wait()
        if root then root.AssemblyLinearVelocity = originalVelocity end
    end
    
    if _G.SpencerResetConfig.antiVoidActive and hum.Health > 0 then
        if root.Position.Y < -350 then
            if not isPhantomActive then isPhantomActive = true phantomY = root.Position.Y cam.CameraType = Enum.CameraType.Scriptable end
            root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = Vector3.zero, Vector3.zero
            root.CFrame = CFrame.new(root.Position.X, -350, root.Position.Z)
            phantomY = phantomY - 4
            cam.CFrame = CFrame.new(root.Position.X, phantomY + 10, root.Position.Z + 20) * CFrame.Angles(math.rad(-25), 0, 0)
        else
            if isPhantomActive then isPhantomActive = false cam.CameraType = Enum.CameraType.Custom if hum then cam.CameraSubject = hum end end
        end
    else
        if isPhantomActive then isPhantomActive = false cam.CameraType = Enum.CameraType.Custom if hum then cam.CameraSubject = hum end end
    end
    
    if _G.SpencerResetConfig.autoResetActive and hum.Health > 0 then
        if hum.Health < _G.SpencerResetConfig.lastHealth then hum.Health = 0 _G.SpencerResetConfig.lastHealth = 100 else _G.SpencerResetConfig.lastHealth = hum.Health end
    else _G.SpencerResetConfig.lastHealth = 100 end
    
    if not _G.HimxConfig.isLooping or _G.HimxConfig.InfPosActive then return end
    if target and target.Character then
        local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local offset = Vector3.zero
            if _G.HimxConfig.posState == "Front" then offset = tRoot.CFrame.LookVector * _G.HimxConfig.currentDistance
            elseif _G.HimxConfig.posState == "Back" then offset = tRoot.CFrame.LookVector * -_G.HimxConfig.currentDistance
            elseif _G.HimxConfig.posState == "Above" then offset = tRoot.CFrame.UpVector * _G.HimxConfig.currentDistance end
            root.CFrame = CFrame.new(tRoot.Position + offset, tRoot.Position)
            if not _G.HimxConfig.FlingMode then root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = Vector3.zero, Vector3.zero end
        end
    end
end)

