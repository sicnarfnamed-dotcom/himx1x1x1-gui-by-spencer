local players = game:GetService("Players")
local runService = game:GetService("RunService")
local localPlayer = players.LocalPlayer
local workspace = game:GetService("Workspace")
local cfg = _G.HimxConfig
local rcfg = _G.SpencerResetConfig

local screenGui = localPlayer:WaitForChild("PlayerGui"):WaitForChild("Himx_Spencer_Unified_V6")

local function getTarget()
    if cfg.targetText == "" then return nil end
    local search = string.lower(cfg.targetText)
    for _, p in pairs(players:GetPlayers()) do
        if p ~= localPlayer and p.Name ~= localPlayer.Name then
            if string.find(string.lower(p.Name), search) or string.find(string.lower(p.DisplayName), search) then return p end
        end
    end
    return nil
end

runService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    if not cam then return end
    local target = getTarget()
    if cfg.viewPlayer and target and target.Character and target.Character:FindFirstChild("Humanoid") then
        cam.CameraType = Enum.CameraType.Custom
        cam.CameraSubject = target.Character.Humanoid
    else
        if localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") and cam.CameraSubject ~= localPlayer.Character.Humanoid and not cfg.viewPlayer then
            cam.CameraSubject = localPlayer.Character.Humanoid
        end
    end
end)

runService.Heartbeat:Connect(function()
    local char = localPlayer.Character
    if not char then return end
    local hum, root, cam = char:FindFirstChild("Humanoid"), char:FindFirstChild("HumanoidRootPart"), workspace.CurrentCamera
    
    if rcfg.antiVoidActive and hum and root and hum.Health > 0 then
        if root.Position.Y < -350 then
            if not _G.HimxIsPhantomActive then _G.HimxIsPhantomActive = true _G.HimxPhantomY = root.Position.Y cam.CameraType = Enum.CameraType.Scriptable end
            root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = Vector3.zero, Vector3.zero
            root.CFrame = CFrame.new(root.Position.X, -350, root.Position.Z)
            _G.HimxPhantomY = _G.HimxPhantomY - 4
            cam.CFrame = CFrame.new(root.Position.X, _G.HimxPhantomY + 10, root.Position.Z + 20) * CFrame.Angles(math.rad(-25), 0, 0)
        else
            if _G.HimxIsPhantomActive then _G.HimxIsPhantomActive = false cam.CameraType = Enum.CameraType.Custom if hum then cam.CameraSubject = hum end end
        end
    else
        if _G.HimxIsPhantomActive then _G.HimxIsPhantomActive = false cam.CameraType = Enum.CameraType.Custom if hum then cam.CameraSubject = hum end end
    end
    
    if rcfg.autoResetActive and hum and hum.Health > 0 then
        if hum.Health < rcfg.lastHealth then hum.Health = 0 rcfg.lastHealth = 100 else rcfg.lastHealth = hum.Health end
    else rcfg.lastHealth = 100 end
    
    if not cfg.isLooping then return end
    local target = getTarget()
    if target and target.Character and root then
        local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local offset = Vector3.zero
            if cfg.posState == "Front" then offset = tRoot.CFrame.LookVector * cfg.currentDistance
            elseif cfg.posState == "Back" then offset = tRoot.CFrame.LookVector * -cfg.currentDistance
            elseif cfg.posState == "Above" then offset = tRoot.CFrame.UpVector * cfg.currentDistance end
            root.CFrame = CFrame.new(tRoot.Position + offset, tRoot.Position)
            root.AssemblyLinearVelocity, root.AssemblyAngularVelocity = Vector3.zero, Vector3.zero
        end
    end
end)

