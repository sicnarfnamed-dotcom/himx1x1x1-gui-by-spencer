local function processPartSlider(input)
    local relativeX = math.clamp((input.Position.X - partSliderTrack.AbsolutePosition.X) / partSliderTrack.AbsoluteSize.X, 0, 1)
    partSliderHandle.Position = UDim2.new(relativeX, -6, 0.5, -8)
    -- Mathematical scaling logic between 0.0001 and 1.0
    local rawSpeed = 0.0001 + (relativeX * (1.0 - 0.0001))
    _G.HimxConfig.PartLoopSpeed = math.floor(rawSpeed * 10000) / 10000
    if _G.HimxUpdatePartLabel then _G.HimxUpdatePartLabel(_G.HimxConfig.PartLoopSpeed) end
end

